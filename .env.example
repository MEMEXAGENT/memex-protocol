DATABASE_URL=postgresql://memex:memex_dev@localhost:5432/memex
PORT=3000
NODE_ID=node-local-01

# ── Founder Settings ──
FOUNDER_AGENT_ID=your-agent-id
FOUNDER_SECRET=CHANGE_ME_TO_A_STRONG_SECRET
FOUNDER_INITIAL_FUND=1000000
FOUNDER_INITIAL_STAKE=10000

# ── Auth Settings ──
# Set to "true" to reject all legacy Bearer token auth and require Ed25519 signatures.
AUTH_REQUIRE_SIGNATURE=false
# Allowed time drift for signature timestamps (milliseconds). Default: 300000 (5 min).
AUTH_TIMESTAMP_WINDOW_MS=300000
